name: Full CI + Artifact Pipeline

on:
  workflow_dispatch:

jobs:

  Job1:
    runs-on: ubuntu-latest

    strategy:
      matrix:
        python-version: [3.11, 3.12]
        include:
          - python-version: 3.11
            DOCKER_TAG: docker-py311
          - python-version: 3.12
            DOCKER_TAG: docker-py312

    steps:
      - name: Checkout
        uses: actions/checkout@v4

      - name: Setup Python
        uses: actions/setup-python@v5
        with:
          python-version: ${{ matrix.python-version }}

      # ✅ هنا بس نستخدم secrets (مش في matrix!)
      - name: Set secret based on version
        run: |
          if [ "${{ matrix.python-version }}" = "3.11" ]; then
            echo "MY_SECRET=${{ secrets.SECRET_PY311 }}" >> $GITHUB_ENV
          else
            echo "MY_SECRET=${{ secrets.SECRET_PY312 }}" >> $GITHUB_ENV
          fi

      - name: Run tests
        run: python -m unittest discover -s tests -v

  # 🔥 2. BUILD ARTIFACT
  Job2:
    needs: Job1
    runs-on: ubuntu-latest

    env:
      IMAGE_NAME: tiny-health-app
      ARTIFACT_NAME: tiny-health-app-${{ github.run_id }}

    steps:
      - name: Checkout repository
        uses: actions/checkout@v4

      - name: Build + Save Docker image
        uses: docker/build-push-action@v5
        with:
          context: .
          file: ./Dockerfile
          push: false
          tags: ${{ env.IMAGE_NAME }}:latest
          outputs: type=docker,dest=${{ env.ARTIFACT_NAME }}.tar

      - name: Upload artifact
        uses: actions/upload-artifact@v4
        with:
          name: ${{ env.ARTIFACT_NAME }}
          path: ${{ env.ARTIFACT_NAME }}.tar