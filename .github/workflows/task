name: Full CI + Artifact Pipeline

on:
  workflow_dispatch:

jobs:

  # 🔥 1. MATRIX CI
  Job1:
    runs-on: ubuntu-latest

    strategy:
      matrix:
        python-version: [3.11, 3.12]

    steps:
      - name: Checkout
        uses: actions/checkout@v4

      - name: Setup Python
        uses: actions/setup-python@v5
        with:
          python-version: ${{ matrix.python-version }}

      # ✅ نحط secret حسب version هنا
      - name: Set secret for Python 3.11
        if: matrix.python-version == '3.11'
        run: echo "MY_SECRET=${{ secrets.SECRET_PY311 }}" >> $GITHUB_ENV

      - name: Set secret for Python 3.12
        if: matrix.python-version == '3.12'
        run: echo "MY_SECRET=${{ secrets.SECRET_PY312 }}" >> $GITHUB_ENV

      - name: Use Secret
        run: echo "Secret length is ${#MY_SECRET}"

      - name: Run tests
        run: python -m unittest discover -s tests -v

  # 🔥 2. BUILD ARTIFACT
  Job2:
    needs: Job1
    runs-on: ubuntu-latest

    env:
      IMAGE_NAME: tiny-health-app
      ARTIFACT_NAME: tiny-health-app-${{ github.run_id }}

    steps:
      - name: Checkout repository
        uses: actions/checkout@v4

      - name: Build + Save Docker image
        uses: docker/build-push-action@v5
        with:
          context: .
          file: ./Dockerfile
          push: false
          tags: ${{ env.IMAGE_NAME }}:latest
          outputs: type=docker,dest=${{ env.ARTIFACT_NAME }}.tar

      - name: Upload artifact
        uses: actions/upload-artifact@v4
        with:
          name: ${{ env.ARTIFACT_NAME }}
          path: ${{ env.ARTIFACT_NAME }}.tar